PORT=5000
NODE_ENV="development"
MONGODB_URI="mongodb://localhost:27017/wedding_invites"
JWT_SECRET="your_very_secret_key_change_this"
FRONTEND_URL="http://localhost:5173"

# Email Configuration
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your_email@example.com"
SMTP_PASS="your_password"
SMTP_FROM="Wedding Invites <no-reply@example.com>"

# Media Storage
UPLOAD_PATH="uploads"
MAX_FILE_SIZE=5242880 # 5MB
VIDEO_MAX_FILE_SIZE=104857600 # 100MB

# Optional AI feature for /api/image-to-website
OPENAI_API_KEY=""
OPENAI_UI_MODEL="gpt-4.1-mini"
